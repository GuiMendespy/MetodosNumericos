   "source": [
    "import numpy as np\n",
    "\n",
    "def estimaPi(k):\n",
    "    l = np.array([])\n",
    "    for n in range(k):\n",
    "        l = np.append(l,[(4*((-1)**n)) * (1/(2*n + 1))])\n",
    "    return(l.sum())"
   ]
  },
  {
   "cell_type": "code",
